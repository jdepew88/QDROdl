# Public site URL (metadata, OG tags). Production:
# NEXT_PUBLIC_SITE_URL=https://qdrodl.app
# Local dev (optional override):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Prisma / intake API)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/qdrodl?schema=public"

# AES-256-GCM for encrypted party fields (32 bytes, base64)
ENCRYPTION_KEY_BASE64=""

# Stripe (joinder checkout)
STRIPE_SECRET_KEY=""
STRIPE_PRICE_JOINDER=""
STRIPE_PRICE_MAIL_FILING=""
STRIPE_SUCCESS_URL="http://localhost:3000/checkout/success"
STRIPE_CANCEL_URL="http://localhost:3000/joinders"
# Production (example):
# STRIPE_SUCCESS_URL="https://qdrodl.app/checkout/success"
# STRIPE_CANCEL_URL="https://qdrodl.app/joinders"
