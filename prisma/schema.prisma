generator client {
  provider = "prisma-client-js"
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  // Kept for backward compatibility; optional mirror of "firstName lastName".
  displayName     String?
  // Stored formatted as (000) 000-0000 after validating 10 digits.
  phone           String?
  emailVerifiedAt DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  verification    EmailVerificationToken[]
  passwordResets  PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Matter {
  id                     String                 @id @default(cuid())
  caseNumber             String
  county                 String
  otherCounty            String?
  dom                    DateTime
  dos                    DateTime
  doj                    DateTime?
  concurrentWithJudgment Boolean                @default(false)
  petitionerId           String
  respondentId           String
  petitionerIsMember     Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  attorneys              AttorneyInfo[]
  altPayeeBeneficiaries  AltPayeeBeneficiary[]
  petitioner             Party                  @relation("Petitioner", fields: [petitionerId], references: [id])
  respondent             Party                  @relation("Respondent", fields: [respondentId], references: [id])
  plans                  PlanSelection[]
}

// Designated beneficiaries of the non-member spouse (alternate payee), e.g. CalPERS Model B.
model AltPayeeBeneficiary {
  id           String  @id @default(cuid())
  matterId     String
  sortOrder    Int     @default(0)
  fullName     String
  relationship String?
  address1     String?
  address2     String?
  matter       Matter  @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
}

model Party {
  id                String   @id @default(cuid())
  role              String
  firstName         String
  lastName          String
  fkaLastName       String?
  selfRepresented   Boolean  @default(false)
  email             String
  phone             String?
  address1          String
  // Optional apt / suite when city, state, postalCode are used for mailing line.
  address2          String?
  city              String?
  state             String?
  postalCode        String?
  dobEnc            String?
  ssnEnc            String?
  spouseType        String?
  petitionerMatters Matter[] @relation("Petitioner")
  respondentMatters Matter[] @relation("Respondent")
}

model PlanSelection {
  id                  String   @id @default(cuid())
  matterId            String
  planKey             String
  isInPayStatus       Boolean  @default(false)
  usesTimeRule        Boolean?
  laceraOption4       Boolean?
  calpersOrderModel   String?
  // CalPERS Model C only: optional Option 3W variant.
  calpersOption3W     Boolean?
  // CalPERS Model C: standard (default) vs dro (second template set).
  calpersModelCForm   String?
  chosenTemplates     String
  matter              Matter   @relation(fields: [matterId], references: [id])
}

model AttorneyInfo {
  id        String  @id @default(cuid())
  matterId  String
  side      String
  name      String
  barNumber String?
  email     String?
  phone     String?
  address1  String?
  address2  String?
  matter    Matter  @relation(fields: [matterId], references: [id])
}
