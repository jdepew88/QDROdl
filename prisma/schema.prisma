generator client {
  provider = "prisma-client-js"
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  // Kept for backward compatibility; optional mirror of "firstName lastName".
  displayName     String?
  // Stored formatted as (000) 000-0000 after validating 10 digits.
  phone           String?
  emailVerifiedAt DateTime?
  /// Staff-only: full super-admin dashboard (also allow SUPER_ADMIN_EMAILS env).
  isSuperAdmin    Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  verification    EmailVerificationToken[]
  passwordResets  PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Matter {
  id                     String                 @id @default(cuid())
  caseNumber             String
  county                 String
  otherCounty            String?
  dom                    DateTime
  dos                    DateTime
  doj                    DateTime?
  concurrentWithJudgment Boolean                @default(false)
  petitionerId           String
  respondentId           String
  /// The login email that created/submitted this intake (used to show matters in the dashboard
  /// even if petitioner/respondent emails differ).
  createdByEmail         String?
  petitionerIsMember     Boolean                @default(true)
  /// Set when intake is submitted and the matter record is created.
  intakeCompletedAt      DateTime?
  /// Pipeline: NEW_INTAKE | OPEN | BEYOND_EMAIL | FILING | AWAITING_FINAL_APPROVAL | CLOSED
  workflowStatus         String                 @default("OPEN")
  /// Quoted / expected fees (cents). Ledger records actual collection.
  quotedOrderPrepCents   Int                    @default(0)
  quotedMailingCents     Int                    @default(0)
  quotedFilingCents      Int                    @default(0)
  amountDueCents         Int                    @default(0)
  splitBill              Boolean                @default(false)
  petitionerShareCents   Int?
  respondentShareCents   Int?
  petitionerPaidAt       DateTime?
  respondentPaidAt       DateTime?
  /// Optional plan-admin email for staff communications (e.g. review letter).
  planAdminEmail         String?
  notesInternal          String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  attorneys              AttorneyInfo[]
  altPayeeBeneficiaries  AltPayeeBeneficiary[]
  generatedDocuments     GeneratedDocument[]
  feeLedgerEntries       FeeLedgerEntry[]
  uploads                MatterUpload[]
  communicationLogs      CommunicationLog[]
  petitioner             Party                  @relation("Petitioner", fields: [petitionerId], references: [id])
  respondent             Party                  @relation("Respondent", fields: [respondentId], references: [id])
  plans                  PlanSelection[]

  @@index([createdByEmail])
}

/// Server-generated lifecycle PDFs / exports (preapproval letter, notices, etc.). Source of truth remains Matter / Party rows.
model GeneratedDocument {
  id           String   @id @default(cuid())
  matterId     String
  type         String
  title        String
  filePath     String
  fileUrl      String
  version      Int      @default(1)
  metadataJson Json?
  createdAt    DateTime @default(now())

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
  @@index([type])
}

// Designated beneficiaries of the non-member spouse (alternate payee), e.g. CalPERS Model B.
model AltPayeeBeneficiary {
  id           String  @id @default(cuid())
  matterId     String
  sortOrder    Int     @default(0)
  fullName     String
  relationship String?
  address1     String?
  address2     String?
  matter       Matter  @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
}

model Party {
  id                String   @id @default(cuid())
  role              String
  firstName         String
  lastName          String
  fkaLastName       String?
  selfRepresented   Boolean  @default(false)
  email             String
  phone             String?
  address1          String
  // Optional apt / suite when city, state, postalCode are used for mailing line.
  address2          String?
  city              String?
  state             String?
  postalCode        String?
  dobEnc            String?
  ssnEnc            String?
  spouseType        String?
  petitionerMatters Matter[] @relation("Petitioner")
  respondentMatters Matter[] @relation("Respondent")
}

model PlanSelection {
  id                  String   @id @default(cuid())
  matterId            String
  planKey             String
  isInPayStatus       Boolean  @default(false)
  usesTimeRule        Boolean?
  laceraOption4       Boolean?
  calpersOrderModel   String?
  // CalPERS Model C only: optional Option 3W variant.
  calpersOption3W     Boolean?
  // CalPERS Model C: standard (default) vs dro (second template set).
  calpersModelCForm   String?
  chosenTemplates     String
  /// Staff: whether a joinder pleading is expected for this plan row.
  joinderRequired     Boolean  @default(false)
  /// Who is the plan "member" (employee/participant) for this specific plan order.
  /// "PETITIONER" means Husband/Petitioner is the plan member; "RESPONDENT" means
  /// Wife/Respondent is the plan member.
  memberPartyRole     String?
  /// Member spouse's employer name for this specific plan order.
  memberEmployerName  String?
  /// Whether the plan has already been joined on the case (joinder filed).
  joinderJoinedInCase Boolean @default(false)
  matter              Matter   @relation(fields: [matterId], references: [id])
}

/// Recorded revenue (actual fees collected), for admin reporting.
model FeeLedgerEntry {
  id          String   @id @default(cuid())
  matterId    String
  category    String
  amountCents Int
  recordedAt  DateTime @default(now())
  note        String?
  /// Idempotency (e.g. Stripe Checkout Session id + line key).
  sourceRef   String?  @unique
  matter      Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
  @@index([recordedAt])
  @@index([category])
}

/// Party / counsel uploads (judgment, statements, etc.).
model MatterUpload {
  id               String   @id @default(cuid())
  matterId         String
  planKey          String?
  category         String
  note             String?  @db.Text
  fileName         String
  filePath         String
  fileUrl          String
  uploadedByEmail  String
  createdAt        DateTime @default(now())
  matter           Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
}

/// Audit trail for staff-sent emails (reminders, draft packages).
model CommunicationLog {
  id          String   @id @default(cuid())
  matterId    String
  kind        String
  channel     String   @default("email")
  targetsJson String   @db.Text
  subject     String?
  bodyPreview String?  @db.Text
  createdAt   DateTime @default(now())
  matter      Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
}

/// Super-admin curated QDRO chat knowledge ("walled garden" answers).
model ChatKnowledgeEntry {
  id             String   @id @default(cuid())
  questionSample String   @db.Text
  answerText     String   @db.Text
  tagsCsv        String?
  isActive       Boolean  @default(true)
  source         String   @default("superadmin")
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model AttorneyInfo {
  id        String  @id @default(cuid())
  matterId  String
  side      String
  name      String
  barNumber String?
  email     String?
  phone     String?
  address1  String?
  address2  String?
  matter    Matter  @relation(fields: [matterId], references: [id])
}
