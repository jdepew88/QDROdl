generator client {
  provider = "prisma-client-js"
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  verification    EmailVerificationToken[]
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Matter {
  id                     String          @id @default(cuid())
  caseNumber             String
  county                 String
  otherCounty            String?
  dom                    DateTime
  dos                    DateTime
  doj                    DateTime?
  concurrentWithJudgment Boolean         @default(false)
  petitionerId           String
  respondentId           String
  petitionerIsMember     Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  attorneys              AttorneyInfo[]
  petitioner             Party           @relation("Petitioner", fields: [petitionerId], references: [id])
  respondent             Party           @relation("Respondent", fields: [respondentId], references: [id])
  plans                  PlanSelection[]
}

model Party {
  id                String   @id @default(cuid())
  role              String
  firstName         String
  lastName          String
  email             String
  phone             String?
  address1          String
  address2          String?
  dobEnc            String?
  ssnEnc            String?
  spouseType        String?
  petitionerMatters Matter[] @relation("Petitioner")
  respondentMatters Matter[] @relation("Respondent")
}

model PlanSelection {
  id              String   @id @default(cuid())
  matterId        String
  planKey         String
  isInPayStatus   Boolean  @default(false)
  usesTimeRule    Boolean?
  laceraOption4   Boolean?
  chosenTemplates String
  matter          Matter   @relation(fields: [matterId], references: [id])
}

model AttorneyInfo {
  id        String  @id @default(cuid())
  matterId  String
  side      String
  name      String
  barNumber String?
  email     String?
  phone     String?
  address1  String?
  address2  String?
  matter    Matter  @relation(fields: [matterId], references: [id])
}
